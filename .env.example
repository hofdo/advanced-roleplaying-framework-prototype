DATABASE_URL=postgres://roleplay:roleplay@localhost:5432/roleplay
ROLEPLAY_STORAGE=postgres
PORT=8080

# Provider type: openai_compatible (default) | llama_cpp | openrouter
LLM_PROVIDER_TYPE=openai_compatible
LLM_BASE_URL=http://localhost:8081/v1
LLM_MODEL=local-model

# API key — plain string or env-var reference (e.g. env:OPENROUTER_API_KEY)
# LLM_API_KEY=

# OpenRouter extras (only used when LLM_PROVIDER_TYPE=openrouter)
# LLM_HTTP_REFERER=https://your-app.example.com
# LLM_X_TITLE=YourAppName
